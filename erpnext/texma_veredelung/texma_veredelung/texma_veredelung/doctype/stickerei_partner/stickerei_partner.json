{
 "doctype": "DocType",
 "name": "Stickerei Partner",
 "module": "Texma Veredelung",
 "engine": "InnoDB",
 "autoname": "field:partner_name",
 "title_field": "partner_name",
 "track_changes": 1,
 "field_order": [
  "partner_name",
  "supplier",
  "aktiv",
  "prioritaet",
  "kapazitaet_stiche_tag",
  "email"
 ],
 "fields": [
  {
   "fieldname": "partner_name",
   "label": "Partnername",
   "fieldtype": "Data",
   "reqd": 1,
   "unique": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "supplier",
   "label": "Lieferant",
   "fieldtype": "Link",
   "options": "Supplier",
   "description": "Verknüpfter ERPNext-Lieferant (für Subcontracting Order).",
   "in_list_view": 1
  },
  {
   "fieldname": "aktiv",
   "label": "Aktiv",
   "fieldtype": "Check",
   "default": "1",
   "in_list_view": 1
  },
  {
   "fieldname": "prioritaet",
   "label": "Priorität",
   "fieldtype": "Int",
   "default": "10",
   "description": "Niedriger = bevorzugt bei Ausschreibung/Direktauftrag.",
   "in_list_view": 1
  },
  {
   "fieldname": "kapazitaet_stiche_tag",
   "label": "Kapazität (Stiche/Tag)",
   "fieldtype": "Int"
  },
  {
   "fieldname": "email",
   "label": "E-Mail (Ausschreibung)",
   "fieldtype": "Data",
   "options": "Email"
  }
 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1, "write": 1, "create": 1, "delete": 1
  },
  {
   "role": "Sales Manager",
   "read": 1, "write": 1, "create": 1
  }
 ]
}
