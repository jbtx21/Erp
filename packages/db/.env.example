# Postgres (EU-Hosting, DSGVO — Kap. 28)
DATABASE_URL="postgresql://texma:texma@localhost:5432/texma?schema=public"

# Laufzeit-Rolle ohne Ownership — Pflicht ab Slice 2 (ADR 0004, RLS-Rollentrennung).
# DATABASE_URL bleibt die Migrations-/Owner-Rolle (prisma migrate); der App-Client
# verbindet sich über texma_app (LOGIN, NOSUPERUSER, NOBYPASSRLS — Anlage via
# packages/db/sql/runtime-role.sql), sonst umgeht der Table Owner RLS still (F13).
# DATABASE_URL_RUNTIME="postgresql://texma_app:texma_app@localhost:5432/texma?schema=public"
