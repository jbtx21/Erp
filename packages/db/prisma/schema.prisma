// Personal Access Token (Xentral-Vorbild PAT): API-Zugriff für externe Agenten/MCP.
// Read-only über die REST-Fassade (/api/v1); RBAC über die hinterlegte Rolle. Nur der
// SHA-256-Hash wird gespeichert (Klartext nur einmalig bei der Ausstellung sichtbar).
model ApiToken {
  id         String    @id @default(cuid())
  name       String
  tokenHash  String    @unique
  role       Role      // bestimmt die Sichtbarkeit (z. B. PRODUKTION → ohne Preise)
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

// Abschlagsrechnung (Xentral „Abschlagsrechnung"): Teil-/Anzahlungsrechnung zu einem Auftrag.
// Eigener Nummernkreis (AR-…); mehrere je Auftrag möglich. Die Schlussrechnung (Invoice)
