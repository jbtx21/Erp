// Mehrstufige Fremdvergabe mit Beistellung + Rücklauf (Kap. 5.3 / T-04, Custom Kap. 31)
model SubProductionOrder {
  id            String   @id @default(cuid())
  number        String   @unique // PA-xxxx-a / -b
  productionId  String
  production    ProductionOrder @relation(fields: [productionId], references: [id])
  sequence      Int      @default(1) // Reihenfolge der Fremdvergabe-Stufe (T-04)
  supplierId    String? // Veredler (null = Inhouse-Veredelung, kein externer Lohnveredler)
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  // Inhouse-Veredelungsschritt (z. B. 2-farbiger Transferdruck im Haus): keine Beistellung/
  // Rücklauf, läuft NACH dem externen Rücklauf am selben Textil (Gate, Kap. 5.4/11).
  inhouse       Boolean  @default(false)
  beistellungVersandtAm DateTime? // Material an Veredler geschickt
  ruecklaufErhaltenAm   DateTime? // Rücklauf gebucht
  status        String   @default("OFFEN")
  // Tiefe T-04: Mengenfluss (Schwund/Ausbeute), Termin, Lohnkosten je Stufe
  beistellMenge  Int? // beigestellte Menge
  ruecklaufMenge Int? // zurückerhaltene Menge (<= Beistellmenge)
  dueDate        DateTime? // zugesagter Rücklauftermin der Stufe
  lohnCents      Int? // Lohnkosten dieser Veredelungsstufe (Nachkalkulation)
  // Beistellung aus dem Auftrag abgeleitet (Veredelungsbezug, Kap. 5.4/11): welche Textilien
  // (Positionsnummern) gehen an diesen Veredler. Steuert das Parallel-/Sequenz-Gate: Stufen an
  // disjunkten Textilien laufen parallel, Stufen am selben Textil bleiben sequenziell (T-04).
  beistellInfo       String? // lesbare Beschreibung der Beistellung (z. B. "200× T-Shirt (Pos. 1)")
  beistellPositionen Int[]   @default([]) // referenzierte Textilpositionen

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([productionId])
  @@index([tenantId])
}

model TimeEntry {
  id           String   @id @default(cuid())
  productionId String
  production   ProductionOrder @relation(fields: [productionId], references: [id])
  userId       String
  minutes      Int // Stechuhr (Kap. 5.2) — Basis Soll-Ist/Nachkalkulation (T-10)
  note         String?
  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])
  // Wiederanlauf nach Notbetrieb (B17): idempotente Nacherfassung — derselbe
  // Schlüssel verhindert Doppelbuchung. @unique lässt mehrere NULL zu.
  idempotencyKey String? @unique
  createdAt    DateTime @default(now())
  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Finanzen / Fibu — Kap. 9, 19
// ─────────────────────────────────────────────────────────────────────────────

model Invoice {
  id          String   @id @default(cuid())
  number      String   @unique // ERP = Rechnungsnummern-Master (Kap. 19)
  // Optional: Musterrechnung (B5) hängt an keinem Auftrag. @unique erlaubt mehrere NULL.
  orderId     String?  @unique
  order       Order?   @relation(fields: [orderId], references: [id])
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  netCents    Int
  taxCents    Int
  grossCents  Int
  issuedAt    DateTime @default(now())
  eInvoiceXml String? // XRechnung/ZUGFeRD (Kap. 19)
  openItem    OpenItem?
  creditNotes CreditNote[] // Gutschriften (Kap. 20)
  sampleLoan  SampleLoan? // Muster-Leihgut-Berechnung (B5)
  // GoBD: finalisierte Rechnung unveränderbar; Korrektur nur via Storno/Gutschrift
  finalized   Boolean  @default(false)
  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])
  // Mandant (ADR 0004, Slice 2) — Pflichtfeld mit Default: der Default "tenant_texma"
  // hält alle bestehenden create-Aufrufe grün (kein Call-Site-Refactor); er fällt in
  // Slice 4, wenn tenantId bei echter Multi-Tenant-Anlage überall explizit gesetzt wird.
  tenantId    String   @default("tenant_texma")
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@index([companyId])
  @@index([tenantId])
}

// Muster-Leihgut (B5, Kap. 37.3). Muster werden verliehen; nach 21 Tagen ohne
// Rückgabe automatisch zum Listenpreis berechnet. Musterbestand läuft über das
// F4-Ledger (StockMove lager=MUSTER); die Frist als DueItem-Wiedervorlage.
enum SampleLoanStatus {
  VERLIEHEN
  ZURUECK
  BERECHNET
}

model SampleLoan {
  id           String           @id @default(cuid())
  companyId    String
  company      Company          @relation(fields: [companyId], references: [id])
  // Einzel-Leihe (Legacy, Auto-Berechnung): genau eine Variante. Mehrartikel-Leihe
  // (Muster/Anprobe, mehrere Lieferanten) nutzt stattdessen SampleLoanLine.
  variantId    String?
  variant      Variant?         @relation(fields: [variantId], references: [id])
  menge        Int?
  zweck        String? // z. B. "Anprobe", "Muster" (Mehrartikel-Leihe)
  quoteId      String? // optionale Zuordnung zu einem Angebot (B5)
  quote        Quote?           @relation(fields: [quoteId], references: [id])
  ausgegebenAm DateTime         @default(now())
  status       SampleLoanStatus @default(VERLIEHEN)
  invoiceId    String?          @unique
  invoice      Invoice?         @relation(fields: [invoiceId], references: [id])
  lines        SampleLoanLine[]
  createdAt    DateTime         @default(now())

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([companyId])
  @@index([status])
  @@index([tenantId])
}

// Position einer Mehrartikel-Leihe: mehrere Artikel von verschiedenen Lieferanten
// (Muster/Anprobe). variantId optional (Katalogartikel), supplierId = Herkunft.
model SampleLoanLine {
  id           String     @id @default(cuid())
  sampleLoanId String
  sampleLoan   SampleLoan @relation(fields: [sampleLoanId], references: [id], onDelete: Cascade)
  description  String
  variantId    String?
  supplierId   String?
  supplier     Supplier?  @relation(fields: [supplierId], references: [id])
  menge        Int
  // Verfügbar ab / zugesagter Liefertermin je Muster-Position (Order-to-make, Kap. 35). null = sofort.
  lieferdatum  DateTime?

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([sampleLoanId])
  @@index([tenantId])
}

// Kostenstelle (B7, Kap. 37.1) — generische Tabelle; Nummern von TEXMA/StB
// befüllbar. Dient der Auswertung, NICHT der Buchung (Gate G1).
model CostCenter {
  id     String @id @default(cuid())
  nummer String @unique
  name   String
  invoices       Invoice[]
  purchaseOrders PurchaseOrder[]
  timeEntries    TimeEntry[]
  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

// DATEV-Export-Protokoll (Kap. 9.2) — „bereits exportiert"-Guard: jeder in einen
// Buchungsstapel übernommene Beleg wird hier append-only vermerkt, damit Folge-Exporte
// ihn überspringen (Doppelbuchung vermeiden). belegart ∈ RECHNUNG/GUTSCHRIFT/EINGANGSRECHNUNG.
model DatevExportEntry {
  id         String   @id @default(cuid())
  belegart   String
  belegKey   String // Belegnummer bzw. -ID
  filename   String
  exportedAt DateTime @default(now())

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([belegart, belegKey])
  @@index([exportedAt])
  @@index([tenantId])
}

model OpenItem {
  id          String   @id @default(cuid())
  invoiceId   String   @unique
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
  openCents   Int
  dueDate     DateTime
  dunningLevel Int     @default(0) // 0..3 (Kap. 9.5)
  payments    PaymentAllocation[]
  dunningNotices DunningNotice[] // append-only Mahnhistorie (B10)

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([dueDate])
  @@index([tenantId])
}

// Kasse (B6, Kap. 37.4) — Bar/EC mit TSE (KassenSichV/§146a AO). CashSale ist
// append-only/WORM: jeder Beleg trägt seine TSE-Signatur und wird nie geändert.
enum PaymentArt {
  BAR
  EC
}

model CashRegister {
  id        String     @id @default(cuid())
  name      String
  sales     CashSale[]
  createdAt DateTime   @default(now())
  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model CashSale {
  id              String       @id @default(cuid())
  belegNr         String       @unique // BON-Nummernkreis (F1)
  registerId      String?
  register        CashRegister? @relation(fields: [registerId], references: [id])
  orderId         String?
  order           Order?       @relation(fields: [orderId], references: [id])
  betragCents     Int
  art             PaymentArt
  kassiertAm      DateTime     @default(now())
  kassierer       String
  tseSignatur     String
  tseSeriennummer String
  tseTxId         String
  createdAt       DateTime     @default(now())

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([kassiertAm])
  @@index([tenantId])
}

// Mahnbeleg (B10, Kap. 9.5) — append-only Historie je Mahnstufe (G2: kein Update).
model DunningNotice {
  id          String   @id @default(cuid())
  openItemId  String
  openItem    OpenItem @relation(fields: [openItemId], references: [id], onDelete: Cascade)
  stufe       Int
  gebuehrCents Int
  textVorlage String
  erzeugtAm   DateTime @default(now())

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([openItemId])
  @@index([tenantId])
}

// Herkunft eines Zahlungseingangs (IA-Objekt-Merge Zahlungsabgleich): ein gemeinsames
// Abgleich-Datenmodell für alle Quellen — automatischer CAMT-Import, Provider-Sync
// (EBICS/PSD2) und manuelle Erfassung. Trennt im vereinheitlichten Abgleich die Herkunft.
enum PaymentSource {
  CAMT // CAMT.053-Datei-Upload (T-13)
  PROVIDER // Bank-Provider-Sync (EBICS/PSD2)
  MANUAL // manuell auf einen OP gebucht (Bar/Überweisungszuordnung)
  PAYPAL // PayPal-Reporting (Brutto klärt OP; Gebühr separater Aufwand)
}

model Payment {
  id           String   @id @default(cuid())
  externalRef  String?  @unique // Bank-/PayPal-Transaktionsreferenz — idempotenter Import (T-13)
  source       PaymentSource @default(MANUAL) // Herkunft (vereinheitlichter Abgleich)
  amountCents  Int      // Brutto (klärt den OP)
  feeCents     Int      @default(0) // Provider-/PayPal-Gebühr (separater Aufwand, nicht im OP-Abgleich)
  currency     String   @default("EUR") // ISO-4217 (PayPal-Fremdwährung)
  bookedAt     DateTime @default(now())
  reference    String? // Verwendungszweck (Banking-Abgleich Kap. 9.4/T-13)
  matched      Boolean  @default(false)
  allocations  PaymentAllocation[]

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([source])
  @@index([matched, source]) // Klärungsliste (matched=false) + Herkunftsfilter (0112)
  @@index([tenantId])
}

model PaymentAllocation {
  id         String   @id @default(cuid())
  paymentId  String
  payment    Payment  @relation(fields: [paymentId], references: [id])
  openItemId String
  openItem   OpenItem @relation(fields: [openItemId], references: [id])
  amountCents Int // tatsächlich geflossenes Geld (Teil-/Voll-/Überzahlung, Kap. 9.4)
  skontoCents Int @default(0) // gewährter Skonto, der den OP zusätzlich schließt (Erlösschmälerung)

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([paymentId, openItemId])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Bank-Anbindung — Kap. 9. Zwei Wege (EBICS / PSD2) hinter einer Abstraktion:
// Kontoauszüge abrufen (AIS → Matching-Pipeline) + SEPA-Überweisungen auslösen (PIS).
// ─────────────────────────────────────────────────────────────────────────────

enum BankConnectionKind {
  EBICS // zertifikatsbasiert, CAMT.053 + pain.001, keine 90-Tage-Re-Auth
  PSD2 // XS2A-API, 90-Tage-SCA-Zustimmung
}

enum PaymentOrderStatus {
  DRAFT // erfasst, noch nicht eingereicht
  SUBMITTED // an den Bank-Provider übergeben
  EXECUTED // vom Provider zur Ausführung angenommen
  REJECTED // vom Provider abgelehnt
}

model BankConnection {
  id                String             @id @default(cuid())
  name              String
  kind              BankConnectionKind
  iban              String // eigenes Konto (Auftraggeber)
  bic               String?
  debtorName        String
  consentValidUntil DateTime? // PSD2: Ablauf der SCA-Zustimmung; EBICS: null
  lastSyncAt        DateTime?
  createdAt         DateTime           @default(now())
  paymentOrders     PaymentOrder[]
  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model PaymentOrder {
  id                     String             @id @default(cuid())
  connectionId           String
  connection             BankConnection     @relation(fields: [connectionId], references: [id])
  messageId              String             @unique // pain.001 MsgId
  status                 PaymentOrderStatus @default(DRAFT)
  totalCents             Int
  requestedExecutionDate String // YYYY-MM-DD
  providerRef            String? // Referenz der Bank/des Providers nach Einreichung
  submittedAt            DateTime?
  createdAt              DateTime           @default(now())
  transfers              PaymentTransfer[]

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([connectionId, status])
  @@index([tenantId])
}

model PaymentTransfer {
  id           String       @id @default(cuid())
  orderId      String
  order        PaymentOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  creditorName String
  creditorIban String
  creditorBic  String?
  amountCents  Int
  remittance   String
  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Archiv / GoBD — Kap. 10. Append-only Audit-Trail.
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  entity    String
  entityId  String
  action    String // CREATE | UPDATE | FINALIZE | STORNO
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([entity, entityId])
  @@index([createdAt])
  @@index([tenantId])
}

// Lückenloser Belegnummernkreis je Belegart und Jahr (GoBD, Kap. 10/19).
// ERP ist Master. Atomare, lückenlose Vergabe via UPSERT+RETURNING in der Repo-
// Schicht (Vorbild: Odoo ir.sequence / ERPNext naming series). `next` = zuletzt
// vergebene laufende Nummer; die erste Vergabe eines Jahres liefert 1.
model NumberSequence {
  key  String // SequenceKey: INVOICE | CREDIT_NOTE | ORDER | QUOTE | INQUIRY | ...
  year Int
  next Int    @default(0)

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@id([key, year])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Beschaffung — Bestellung / Wareneingang — Kap. 6, 5.6. Testfälle T-05, T-12.
// ─────────────────────────────────────────────────────────────────────────────

enum PurchaseOrderStatus {
  ENTWURF
  BESTELLT
  TEILWEISE_ERHALTEN
  ERHALTEN
}

model PurchaseOrder {
  id          String   @id @default(cuid())
  number      String   @unique
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  // Beschaffung für einen Produktionsauftrag (Multi-Lieferant-Gate, Kap. 5.6/T-05)
  productionId String?
  production   ProductionOrder? @relation(fields: [productionId], references: [id])
  status      PurchaseOrderStatus @default(ENTWURF)
  lines       PurchaseOrderLine[]
  goodsReceipts GoodsReceipt[]
  incomingInvoices IncomingInvoice[] // 3-Way-Match (Kap. 9.6)
  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])
  createdAt   DateTime @default(now())

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([supplierId])
  @@index([productionId])
  @@index([tenantId])
}

model PurchaseOrderLine {
  id              String  @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  variantId       String
  variant         Variant @relation(fields: [variantId], references: [id])
  qty             Int
  ekCents         Int
  sources         PurchaseOrderLineSource[]

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([purchaseOrderId])
  @@index([tenantId])
}

// Bedarfsquelle einer Bestellposition (MTO, Kap. 6.1): welche Kundenaufträge/Leihen
// die Menge ausgelöst haben — PO ↔ Auftrag rückverfolgbar (Abgrenzung zu T-12:
// Mindestbestand-Bestellungen haben keine Quellen). Additiv, nur beim
// Auftragsbedarf-Pfad gefüllt.
model PurchaseOrderLineSource {
  id                  String  @id @default(cuid())
  purchaseOrderLineId String
  purchaseOrderLine   PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id])
  // Kundenauftrag; null bei Muster-Leihen oder nicht auflösbarer Referenz.
  orderId             String?
  order               Order?  @relation(fields: [orderId], references: [id])
  ref                 String // Belegreferenz (Auftragsnummer bzw. Leih-Id)
  qty                 Int

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([purchaseOrderLineId])
  @@index([orderId])
  @@index([tenantId])
}

model GoodsReceipt {
  id              String  @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  receivedAt      DateTime @default(now())
  lines           GoodsReceiptLine[]

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([purchaseOrderId])
  @@index([tenantId])
}

model GoodsReceiptLine {
  id             String  @id @default(cuid())
  goodsReceiptId String
  goodsReceipt   GoodsReceipt @relation(fields: [goodsReceiptId], references: [id])
  variantId      String
  variant        Variant @relation(fields: [variantId], references: [id])
  receivedQty    Int
  // EK je Stück laut Lieferschein/Eingang (Kap. 9.6): Abgleich gegen den Bestell-EK
  // (PurchaseOrderLine.ekCents). null = kein EK am Eingang erfasst.
  ekCents        Int?

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([goodsReceiptId])
  @@index([tenantId])
}

// Lagerbestand je Variante; Mindestbestand-Reorder Transferdrucke (Kap. 6.3 / T-12)
// Echtes Multi-Lager (statt festes StockLager-Enum): beliebige Läger + optionale
// Lagerplätze (parentId-Baum). Das Enum bleibt vorerst additiv bestehen (Strangler);
// warehouseId verweist parallel auf den Warehouse-Datensatz. Die 4 bisherigen Läger
// werden als Warehouse-Seeds migriert (Migration 0075).
enum WarehouseKind {
  HAUPT
  MUSTER
  SHOWROOM
  TRANSFERDRUCK
  SONSTIGE
}

model Warehouse {
  id        String        @id @default(cuid())
  code      String        @unique // kurzer eindeutiger Code (z. B. HAUPT, LAGER-2)
  name      String
  kind      WarehouseKind @default(SONSTIGE)
  parentId  String? // optionaler Lagerplatz/Bin innerhalb eines Lagers
  parent    Warehouse?    @relation("WarehouseTree", fields: [parentId], references: [id])
  children  Warehouse[]   @relation("WarehouseTree")
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())

  stockMoves        StockMove[]
  stockLevels       StockLevel[]
  stockReservations StockReservation[]
  stockThresholds   StockThreshold[]

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([kind])
  @@index([tenantId])
}

model StockLevel {
  id        String  @id @default(cuid())
  variantId String  @unique
  variant   Variant @relation(fields: [variantId], references: [id])
  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  qty       Int     @default(0)
  minStock  Int     @default(0)
  updatedAt DateTime @updatedAt
  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

// Bestands-Bewegungs-Ledger (F4, Kap. 37.1) — Vorbild Odoo stock.move/quants.
// Append-only: der Bestand ist die Summe der Bewegungen, niemals direkt gesetzt.
// `StockLevel` bleibt materialisierter Cache des HAUPT-Lagers; MUSTER-Lager wird
// getrennt geführt (B5 Muster-Leihgut).
enum StockMoveReason {
  EROEFFNUNG // Anfangsbestand bei Ledger-Einführung
  WARENEINGANG
  VERBRAUCH
  INVENTUR // Korrektur aus Inventur (B16)
  KORREKTUR
  MUSTER // Ausgabe/Rücknahme Musterware (B5)
}

enum StockLager {
  HAUPT
  MUSTER
  SHOWROOM
  TRANSFERDRUCK
}

model StockMove {
  id        String          @id @default(cuid())
  variantId String
  variant   Variant         @relation(fields: [variantId], references: [id])
  deltaQty  Int // +Zugang / −Abgang
  grund     StockMoveReason
  lager     StockLager      @default(HAUPT)
  warehouseId String?
  warehouse   Warehouse?    @relation(fields: [warehouseId], references: [id])
  belegRef  String? // Verweis auf auslösenden Beleg (PO/Order/Inventur)
  createdAt DateTime        @default(now())

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([variantId, lager])
  @@index([variantId, warehouseId])
  @@index([createdAt])
  @@index([tenantId])
}

// Vormerkung/Reservierung gegen laufende Aufträge: bindet Bestand an einen Beleg, ohne
// ihn zu verbrauchen. Verfügbar = Ledger-Saldo − Summe AKTIVer Reservierungen (je Lager).
enum StockReservationStatus {
  AKTIV
  ERLEDIGT // in Verbrauch/Lieferung überführt
  STORNIERT
}

model StockReservation {
  id         String                 @id @default(cuid())
  variantId  String
  variant    Variant                @relation(fields: [variantId], references: [id])
  lager      StockLager             @default(HAUPT)
  warehouseId String?
  warehouse   Warehouse?            @relation(fields: [warehouseId], references: [id])
  qty        Int // reservierte Menge (>0)
  orderId    String? // auslösender Auftrag (optional)
  belegRef   String? // Anzeige-Referenz (z. B. Auftragsnummer)
  note       String?
  status     StockReservationStatus @default(AKTIV)
  createdAt  DateTime               @default(now())
  releasedAt DateTime?

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([variantId, lager, status])
  @@index([orderId])
  @@index([tenantId])
}

// Meldebestand je Variante × Lager (v. a. Transferdrucke): unterschreitet der VERFÜGBARE
// Bestand minQty, wird automatisch benachrichtigt. `alerting` ist eine Flankensteuerung,
// damit nur beim Übergang gemeldet wird (kein wiederholtes Spammen).
model StockThreshold {
  id        String     @id @default(cuid())
  variantId String
  variant   Variant    @relation(fields: [variantId], references: [id])
  lager     StockLager @default(TRANSFERDRUCK)
  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  minQty    Int
  alerting  Boolean    @default(false)
  updatedAt DateTime   @updatedAt

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([variantId, lager])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Eingangsrechnung + 3-Way-Match — Kap. 9.6
// ─────────────────────────────────────────────────────────────────────────────

enum IncomingInvoiceStatus {
  ERFASST
  GEPRUEFT // 3-Way-Match ok
  GESPERRT // Abweichung (3-Way / EK)
  FREIGEGEBEN // nach EK-Abgleich zur Zahlung freigegeben (Kap. 9.4)
  BEZAHLT
}

// EK-Abgleich-Status (Rechnung ↔ Artikelstammdaten): OFFEN bis geprüft, dann OK/ABWEICHUNG/PRUEFUNG.
enum EkCheckStatus {
  OFFEN
  OK
  ABWEICHUNG
  PRUEFUNG
}

// Herkunft der Eingangsrechnung (GetMyInvoices-Vorbild: ein zentraler Beleg-Eingang).
enum IncomingInvoiceSource {
  E_RECHNUNG // CII/XRechnung (EN16931)
  OCR // PDF/Scan via Texterkennung
  MANUAL // von Hand erfasst
}

model IncomingInvoice {
  id          String   @id @default(cuid())
  number      String
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  // Bezug zur Bestellung für den 3-Way-Match (Kap. 9.6)
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  netCents    Int
  taxCents    Int
  grossCents  Int
  status      IncomingInvoiceStatus @default(ERFASST)
  receivedAt  DateTime @default(now())
  // Herkunft + GoBD-Quellbeleg (E-Rechnung-XML bzw. OCR-Rohtext).
  source      IncomingInvoiceSource @default(E_RECHNUNG)
  eInvoiceXml String?
  // Zahlungskonditionen (Snapshot der Lieferantenkonditionen bei Erfassung, Kap. 9.4)
  issueDate   DateTime?
  dueDate     DateTime? // Nettofälligkeit = Rechnungsdatum + Zahlungsziel
  skontoPercent Int?
  skontoDays    Int?
  skontoUntil   DateTime? // letzter Tag mit Skontoabzug
  // EK-Abgleich + Zahlungsfreigabe (GetMyInvoices: prüfen → freigeben → zahlen)
  ekCheckStatus EkCheckStatus @default(OFFEN)
  freigegebenVon String?
  freigegebenAm  DateTime?
  paidAt          DateTime?
  paymentAmountCents Int? // tatsächlich gezahlter Betrag (ggf. abzüglich Skonto)
  lines       IncomingInvoiceLine[]

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([supplierId, number])
  @@index([status])
  @@index([tenantId])
}

// Position einer Eingangsrechnung (für den EK-Abgleich gegen die Artikelstammdaten).
model IncomingInvoiceLine {
  id          String   @id @default(cuid())
  incomingInvoiceId String
  incomingInvoice   IncomingInvoice @relation(fields: [incomingInvoiceId], references: [id], onDelete: Cascade)
  position    Int
  description String
  supplierSku String? // Lieferanten-Artikelnummer (Auflösung auf die interne Variante)
  variantId   String?
  variant     Variant? @relation(fields: [variantId], references: [id])
  qty         Int
  unitEkCents Int // berechneter EK je Stück (netto)
  lineNetCents Int

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([incomingInvoiceId])
  @@index([tenantId])
}

