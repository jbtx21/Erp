// TEXMA ERP — Kerndatenmodell (modularer Monolith)
// Quelle: docs/lastenheft.md. Kapitelbezüge als // (Kap. x) annotiert.
// Make-or-break: echte Varianten (Kap. 2.1/T-02), ShopConnector→Company (Kap. 3.2/T-01).

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Mandanten — ADR 0004 (RLS-Mandantenfähigkeit), Slice 1: Fundament
// ─────────────────────────────────────────────────────────────────────────────

// Mandant = eine Tenant-Zeile. Slice 1 hängt tenantId ADDITIV/nullable an die
// Wurzel-Entitäten (Backfill auf den Default-Tenant "tenant_texma"); NOT NULL +
// RLS-Policies folgen in Slice 2, die Kinder-Tabellen in Slice 3 (ADR 0004).
model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  users     User[]
  companies Company[]
  suppliers Supplier[]
  articles  Article[]
  quotes    Quote[]
  orders    Order[]
  invoices  Invoice[]
  // Slice-3-Rückrelationen (ADR 0004): Prisma verlangt die Gegenseite jeder
  // tenantId-Relation. Generiert via scripts/rls-inventory.mjs --patch-schema.
  session Session[]
  accessLog AccessLog[]
  customerSupplierPriceGroup CustomerSupplierPriceGroup[]
  contact Contact[]
  deliveryAddress DeliveryAddress[]
  logoVersion LogoVersion[]
  markupConfig MarkupConfig[]
  markupRule MarkupRule[]
  stickereiStaffel StickereiStaffel[]
  stickereiAusschreibung StickereiAusschreibung[]
  stickereiAngebot StickereiAngebot[]
  stickereiAngebotStaffel StickereiAngebotStaffel[]
  mailAccount MailAccount[]
  callLog CallLog[]
  collection Collection[]
  mediaAsset MediaAsset[]
  finishingSpec FinishingSpec[]
  variant Variant[]
  variantComponent VariantComponent[]
  variantAttribute VariantAttribute[]
  axisValue AxisValue[]
  sizeRun SizeRun[]
  priceGroupPrice PriceGroupPrice[]
  priceGroupPriceTier PriceGroupPriceTier[]
  variantEkTier VariantEkTier[]
  customerPriceTier CustomerPriceTier[]
  supplierContact SupplierContact[]
  supplierItem SupplierItem[]
  shopConnector ShopConnector[]
  collectiveOrder CollectiveOrder[]
  portalUser PortalUser[]
  portalSession PortalSession[]
  lead Lead[]
  inquiry Inquiry[]
  quoteLine QuoteLine[]
  orderLine OrderLine[]
  bomTemplate BomTemplate[]
  bomTemplateItem BomTemplateItem[]
  productionOrder ProductionOrder[]
  bomItem BomItem[]
  subProductionOrder SubProductionOrder[]
  timeEntry TimeEntry[]
  sampleLoan SampleLoan[]
  sampleLoanLine SampleLoanLine[]
  costCenter CostCenter[]
  datevExportEntry DatevExportEntry[]
  openItem OpenItem[]
  cashRegister CashRegister[]
  cashSale CashSale[]
  dunningNotice DunningNotice[]
  payment Payment[]
  paymentAllocation PaymentAllocation[]
  bankConnection BankConnection[]
  paymentOrder PaymentOrder[]
  paymentTransfer PaymentTransfer[]
  auditLog AuditLog[]
  numberSequence NumberSequence[]
  purchaseOrder PurchaseOrder[]
  purchaseOrderLine PurchaseOrderLine[]
  purchaseOrderLineSource PurchaseOrderLineSource[]
  goodsReceipt GoodsReceipt[]
  goodsReceiptLine GoodsReceiptLine[]
  warehouse Warehouse[]
  stockLevel StockLevel[]
  stockMove StockMove[]
  stockReservation StockReservation[]
  stockThreshold StockThreshold[]
  incomingInvoice IncomingInvoice[]
  incomingInvoiceLine IncomingInvoiceLine[]
  deliveryNote DeliveryNote[]
  deliveryNoteLine DeliveryNoteLine[]
  creditNote CreditNote[]
  apiToken ApiToken[]
  abschlagsrechnung Abschlagsrechnung[]
  gutschein Gutschein[]
  complaint Complaint[]
  dueItem DueItem[]
  finishingTargetTime FinishingTargetTime[]
  approvalThreshold ApprovalThreshold[]
  outboxEvent OutboxEvent[]
  integrationLog IntegrationLog[]
  recordComment RecordComment[]
  recordActivity RecordActivity[]
  recordAttachment RecordAttachment[]
  notification Notification[]
  emailTemplate EmailTemplate[]
  dashboardChart DashboardChart[]
  numberCard NumberCard[]
  dashboard Dashboard[]
  dashboardItem DashboardItem[]
  newsletterCampaign NewsletterCampaign[]
  crmLead CrmLead[]
  opportunity Opportunity[]
  calendarEvent CalendarEvent[]
  internalMessage InternalMessage[]
  appSetting AppSetting[]
  employee Employee[]
  vacationRequest VacationRequest[]
  integrationSetting IntegrationSetting[]
  passwordResetToken PasswordResetToken[]
  task Task[]
  userPreference UserPreference[]
  automationRule AutomationRule[]
  contactLink ContactLink[]
  archivedDocument ArchivedDocument[]
}

// ─────────────────────────────────────────────────────────────────────────────
// Identity & Access — Kap. 12 (Rollen), Kap. 14 (2FA), Kap. 28 (Zugriffs-Logging)
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  BUERO // Vertrieb/Auftrag/Faktura
  PRODUKTION // kein Preis-/Kundenzugriff (Kap. 12)
  BUCHHALTUNG
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         Role
  totpSecret   String? // TOTP-2FA Pflicht für alle (Kap. 14)
  totpEnabled  Boolean   @default(false)
  active       Boolean   @default(true)
  failedLoginCount Int   @default(0) // Lockout-Zähler (Kap. 14)
  lockedUntil  DateTime? // gesperrt bis (nach zu vielen Fehlversuchen)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  auditEntries AuditLog[]
  accessLogs   AccessLog[]
  resetTokens  PasswordResetToken[]
  preferences  UserPreference[]
  // Mandant (ADR 0004, Slice 2) — Pflichtfeld mit Default: der Default "tenant_texma"
  // hält alle bestehenden create-Aufrufe grün (kein Call-Site-Refactor); er fällt in
  // Slice 4, wenn tenantId bei echter Multi-Tenant-Anlage überall explizit gesetzt wird.
  tenantId     String   @default("tenant_texma")
  tenant       Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

// Server-seitige Session (Kap. 14). tokenHash = SHA-256 des Cookie-Tokens — der
// Klartext-Token liegt nur im httpOnly-Cookie, nie in der DB.
model Session {
  id          String   @id @default(cuid())
  tokenHash   String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  expiresAt   DateTime
  pendingTotp Boolean  @default(false) // Passwort ok, 2FA noch ausstehend
  createdAt   DateTime @default(now())

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
}

// Zugriffs-Logging auf personenbezogene Daten (Kap. 28)
model AccessLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  entity    String
  entityId  String
  action    String // VIEW | EXPORT
  createdAt DateTime @default(now())

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([entity, entityId])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Stammdaten — Kunden/CRM — Kap. 8 (Firma 1:n Kontakte/Lieferadressen), 7.2, 5.4
// ─────────────────────────────────────────────────────────────────────────────

enum PriceGroupKind {
  STANDARD
  TOP
  PREMIUM
  SCHULE
  WIEDERVERKAEUFER
  AGENTUR
}

model PriceGroup {
  id        String          @id @default(cuid())
  kind      PriceGroupKind  @unique
  name      String
  companies Company[]
  prices    PriceGroupPrice[]
  priceTiers PriceGroupPriceTier[]
  customerSupplierGroups CustomerSupplierPriceGroup[]
}

// (Lieferanten-Aufschläge liegen seit Phase 1 in der EINEN Regel-Engine: MarkupRule mit supplierId
//  × priceGroupId, finishingType=null. Die frühere Tabelle SupplierMarkup wurde in 0119 entfernt.)

// Kundengruppe je (Kunde × Lieferant): ein Kunde kann bei HAKRO „Premium", bei Stanley
// „Standard" sein. Fehlt der Eintrag → Default-Preisgruppe der Firma → sonst STANDARD.
model CustomerSupplierPriceGroup {
  id           String     @id @default(cuid())
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplierId   String
  supplier     Supplier   @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  priceGroupId String
  priceGroup   PriceGroup @relation(fields: [priceGroupId], references: [id])

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([companyId, supplierId])
  @@index([supplierId])
  @@index([tenantId])
}

// Firma = Kunde. KEIN 1:1-Import Firma↔Kontakt (Kap. 8.3).
model Company {
  id           String        @id @default(cuid())
  customerNumber String?     @unique // sprechende Kundennummer (KD-JJJJ-NNNN), Xentral-Benchmark
  name         String
  branche      String?
  gesperrtAm     DateTime?   // DSGVO-Sperre (B12, Kap. 28)
  anonymisiertAm DateTime?   // DSGVO-Anonymisierung (B12)
  zahlungszielTage Int        @default(14)
  mahnsperre   Boolean       @default(false) // Kap. 9.5
  // Liefersperre (Xentral-Benchmark): blockt den Versand (gesperrte Kunden erscheinen
  // nicht in der Versandliste). Grund optional zur Nachvollziehbarkeit.
  liefersperre      Boolean @default(false)
  liefersperreGrund String?
  // Zuordnung/Buchhaltung: Debitorenkonto (DATEV/SKR), Belegsprache, Währung, Betreuer (Innendienst).
  debitorenkonto String?
  belegsprache   String? @default("DE") // DE | EN
  waehrung       String? @default("EUR")
  betreuer       String? // Vertriebs-/Innendienstbetreuer (frei)
  email          String? // zentrale E-Mail der Firma (Belegversand); aus Lead-Konvertierung übernommen
  // Rechnungsadresse (Pflicht auf Rechnung, § 14 UStG) + Steuerangaben (Paket 1)
  street       String?
  zip          String?
  city         String?
  country      String        @default("DE")
  vatId        String? // USt-IdNr. (B2B/innergemeinschaftlich)
  taxNumber    String? // Steuernummer
  // Steuerregel je Kunde (zentral, Xentral-Benchmark): steuert die USt-Behandlung der Belege.
  // INLAND | EU_B2B (innergemeinschaftlich, Reverse-Charge §13b) | DRITTLAND (Ausfuhr) | KLEINUNTERNEHMER
  taxRule      String? @default("INLAND")
  // Bankverbindung + SEPA-Lastschriftmandat (für Lastschriftverfahren, Kap. 9)
  iban           String?
  bic            String?
  bankName       String?
  sepaMandateRef  String? // Mandatsreferenz
  sepaMandateDate String? // Mandatsdatum (ISO YYYY-MM-DD)
  // Zahlungsbedingungen
  skontoPercent Int? // Skonto-% (z. B. 2)
  skontoDays    Int? // Skonto-Frist (Tage)
  paymentMethod String? // UEBERWEISUNG | LASTSCHRIFT | BAR
  // Lieferbedingungen + interne Vermerke + Bonität
  lieferbedingung String? // z. B. Versandart/Incoterm
  notiz         String?
  kreditlimitCents Int? // Kreditlimit (AR-Risiko)
  priceGroupId String
  priceGroup   PriceGroup    @relation(fields: [priceGroupId], references: [id])
  // Stickerei-Partnerlogik (Kap. 5.4 / Custom): Partner + Stickdatei steuern Direkt- vs. Angebotsprozess
  stickereiPartnerId String?
  stickereiPartner   Supplier? @relation("StickereiPartner", fields: [stickereiPartnerId], references: [id])
  hatStickdatei      Boolean   @default(false)

  contacts        Contact[]
  deliveryAddresses DeliveryAddress[]
  logoVersions    LogoVersion[]
  quotes          Quote[]
  orders          Order[]
  collectiveOrders CollectiveOrder[]
  invoices        Invoice[]
  abschlaege      Abschlagsrechnung[]
  crmLeads        CrmLead[] // vereinheitlichter CRM-Funnel (IA-Merge)
  inquiries       Inquiry[] // Anfrage-Funnel (B20)
  lead            Lead? // aus Lead konvertiert (B15)
  portalUsers     PortalUser[] // Kundenportal-Logins (B13)
  sampleLoans     SampleLoan[] // Muster-Leihgut (B5)
  priceTiers      CustomerPriceTier[] // kundenindividuelle Mengenstaffel (B4)
  supplierGroups  CustomerSupplierPriceGroup[] // Preisgruppe je Lieferant (Premium@HAKRO, Standard@…)
  shopConnectors  ShopConnector[] // T-01: Shops mappen auf die Firma, nicht auf Mitarbeiter
  opportunities   Opportunity[] // Verkaufschancen (CRM)
  callLogs        CallLog[] // Anrufprotokoll (Telefon-Modul)
  // Mandant (ADR 0004, Slice 2) — Pflichtfeld mit Default: der Default "tenant_texma"
  // hält alle bestehenden create-Aufrufe grün (kein Call-Site-Refactor); er fällt in
  // Slice 4, wenn tenantId bei echter Multi-Tenant-Anlage überall explizit gesetzt wird.
  tenantId        String   @default("tenant_texma")
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([name])
  @@index([tenantId])
}

model Contact {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  firstName String
  lastName  String
  email     String?
  phone     String?
  role      String? // Funktion im Unternehmen
  newsletterOptIn Boolean @default(false) // DSGVO-Einwilligung Newsletter (Kap. 28)
  gesperrtAm     DateTime? // DSGVO-Sperre (B12, Kap. 28)
  anonymisiertAm DateTime? // DSGVO-Anonymisierung (B12)
  createdAt DateTime @default(now())
  links     ContactLink[] // zusätzliche Verknüpfungen (Dynamic-Link, CRM)

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([companyId])
  @@index([tenantId])
}

model DeliveryAddress {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  label     String
  street    String
  zip       String
  city      String
  country   String  @default("DE")
  isDefault Boolean @default(false) // Standard-Lieferadresse (Beleg-Vorbelegung), Xentral-Benchmark
  orders    Order[]

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([companyId])
  @@index([tenantId])
}

// Logo-Versionen versioniert; genau eine aktiv (Kap. 7.2)
model LogoVersion {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])
  version    Int
  fileRef    String // Verweis auf externen Speicher (Kap. 7.1)
  active     Boolean  @default(false)
  replacedAt DateTime?
  createdAt  DateTime @default(now())
  // Optionaler Aufschlagsfaktor-Override je Logo (gewinnt über die globalen Regeln, Kap. 4.4).
  markupFactor Float?
  // Hochgeladene Stickdatei (beliebiges Format, Kap. 7.1) — inline in der DB gespeichert.
  fileName   String?
  mimeType   String?
  fileSize   Int?
  fileData   Bytes?

  stickereiStaffeln StickereiStaffel[]
  ausschreibungen   StickereiAusschreibung[]

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([companyId, version])
  @@index([companyId, active])
  @@index([tenantId])
}

// Konfigurierbarer Aufschlagsfaktor (Kap. 4.4) — „jederzeit neu definierbar": EIN globaler
// Standardfaktor (Singleton-Zeile id=GLOBAL), durch MarkupRule je Parameter überschreibbar.
model MarkupConfig {
  id            String   @id @default("GLOBAL")
  defaultFactor Float    @default(1.88)
  updatedAt     DateTime @updatedAt
  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

// Eine Aufschlags-Regel: Faktor unter optionalen, UND-verknüpften Bedingungen
// (Kundengruppe/Veredelungsart/Mengen- und EK-Wertbereich). Spezifischere Regel gewinnt.
model MarkupRule {
  id            String   @id @default(cuid())
  factor        Float
  label         String?
  priceGroupId  String? // Kundengruppe (Preisgruppe)
  // Lieferant als Bedingung (Variante A): VK = EK × Faktor(Lieferant × Kundengruppe). Der
  // Fold-in von SupplierMarkup macht die Regel-Engine zur EINEN Engine für Artikel + Veredelung.
  supplierId    String? // FK auf Supplier (in der Migration ergänzt); null = lieferantenunabhängig
  finishingType String? // Veredelungsart (STICKEREI/DRUCK/TRANSFER)
  minMenge      Int?
  maxMenge      Int?
  minEkCents    Int?
  maxEkCents    Int?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([supplierId])
  @@index([tenantId])
}

// Variable Mengenstaffeln je Logo (Kap. 4.4 / T-15): die Stickerei gibt uns nur ihren VK
// (= unseren Stick-EK) je Stück gestaffelt nach Bestellmenge; Staffelgrenzen frei wählbar
// und je Logo abweichend. Gespeichert wird nur der manuell erfasste Stick-EK — unser
// VK = EK × 1,88 (Aufschlagsfaktor) wird berechnet, nicht persistiert.
model StickereiStaffel {
  id            String      @id @default(cuid())
  logoVersionId String
  logoVersion   LogoVersion @relation(fields: [logoVersionId], references: [id], onDelete: Cascade)
  minMenge      Int // untere Staffelgrenze in Stück (1, 10, 25, 50, 100, 250 …)
  ekCents       Int // Stick-EK je Stück in Cent (VK der Stickerei an uns), manuell erfasst
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([logoVersionId, minMenge])
  @@index([logoVersionId])
  @@index([tenantId])
}

// Ausschreibung eines Logos an mehrere Stickerei-Partner (Kap. 5.4): neues Logo / kein
// Partner → mehrere Angebote (Stick-EK-Staffeln) einholen, vergleichen, eines wählen.
model StickereiAusschreibung {
  id            String      @id @default(cuid())
  logoVersionId String
  logoVersion   LogoVersion @relation(fields: [logoVersionId], references: [id], onDelete: Cascade)
  status        String      @default("OFFEN") // OFFEN | ENTSCHIEDEN | ABGEBROCHEN
  gewinnerAngebotId String?
  createdAt     DateTime    @default(now())
  decidedAt     DateTime?
  angebote      StickereiAngebot[]

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([logoVersionId])
  @@index([tenantId])
}

// Angebot eines Stickerei-Partners in einer Ausschreibung (Stick-EK je Mengenstaffel).
model StickereiAngebot {
  id              String   @id @default(cuid())
  ausschreibungId String
  ausschreibung   StickereiAusschreibung @relation(fields: [ausschreibungId], references: [id], onDelete: Cascade)
  supplierId      String
  supplier        Supplier @relation("StickereiAngebote", fields: [supplierId], references: [id])
  notiz           String?
  createdAt       DateTime @default(now())
  staffeln        StickereiAngebotStaffel[]

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([ausschreibungId])
  @@index([tenantId])
}

model StickereiAngebotStaffel {
  id        String @id @default(cuid())
  angebotId String
  angebot   StickereiAngebot @relation(fields: [angebotId], references: [id], onDelete: Cascade)
  minMenge  Int
  ekCents   Int

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([angebotId, minMenge])
  @@index([tenantId])
}

// Anrufprotokoll (Telefon-Modul): nachvollziehbar wer wann mit wem worüber telefoniert
// hat, inkl. Rückruf-Nachverfolgung. Optional an eine Firma/Kunde verknüpft.
enum CallDirection {
  EINGEHEND
  AUSGEHEND
}

enum CallStatus {
  ERLEDIGT
  OFFEN
  RUECKRUF
}

// Mehrere E-Mail-Konten (IONOS-Postfächer): Senden/Empfangen je Konto, je eines als
// Standard für ein-/ausgehend. Passwort AES-256-GCM verschlüsselt (nie im Klartext/Log).
model MailAccount {
  id              String   @id @default(cuid())
  name            String // Anzeigename
  emailAddress    String   @unique // Absender (From) + Login
  imapHost        String   @default("imap.ionos.de")
  imapPort        Int      @default(993)
  smtpHost        String   @default("smtp.ionos.de")
  smtpPort        Int      @default(587)
  username        String? // Login, falls abweichend von emailAddress
  passwordEnc     String? // AES-256-GCM-verschlüsseltes Passwort (Kap. 28)
  enableIncoming  Boolean  @default(true)
  enableOutgoing  Boolean  @default(true)
  defaultIncoming Boolean  @default(false)
  defaultOutgoing Boolean  @default(false)
  disabled        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([defaultOutgoing])
  @@index([defaultIncoming])
  @@index([tenantId])
}

model CallLog {
  id            String        @id @default(cuid())
  richtung      CallDirection
  telefonnummer String
  kontaktName   String? // Name des Anrufers/Angerufenen
  companyId     String?
  company       Company?      @relation(fields: [companyId], references: [id])
  bearbeiter    String? // interner Benutzer (E-Mail), der telefoniert hat
  zeitpunkt     DateTime      @default(now())
  dauerSek      Int?
  grund         String // weswegen — Betreff/Anliegen
  ergebnis      String? // Notiz/Ausgang des Gesprächs
  status        CallStatus    @default(ERLEDIGT)
  createdAt     DateTime      @default(now())

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([companyId])
  @@index([status])
  @@index([zeitpunkt])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Stammdaten — Artikel & echte Varianten — Kap. 2.1, 8, 11, 27 (15k Artikel)
// ─────────────────────────────────────────────────────────────────────────────

// Artikeltyp-Diskriminator (Xentral-typisierte Artikel): trennt Lagerartikel von
// Veredelung/Dienstleistung/Stückliste. Strangler: ergänzt das ältere isVeredelung-Flag
// (additiv, beide bleiben konsistent), damit Logos/Dienstleistungen nicht im regulären
// Artikelkatalog auftauchen. FINISHING wird aus isVeredelung=true backfilled.
enum ArticleType {
  STOCK // Lagerartikel (Textil etc.)
  FINISHING // Veredelung/Logo (Stick/Druck/Transfer)
  SERVICE // Dienstleistung (kein Lager)
  BOM // Stückliste/Set
}

model Article {
  id          String    @id @default(cuid())
  sku         String    @unique // Artikelnummer (Pflicht) — überall sichtbar
  name        String    // Artikelname (Pflicht)
  description String    // Artikelbeschreibung (Pflicht-Stammdatum) — war optional, jetzt zwingend
  // Verbindliche Basis-Preise je Artikel (Pflicht, Cent). „Standard + Übersteuerung": Preisgruppen-/
  // Lieferanten-/Staffel-Preise auf Variantenebene übersteuern; fehlt eine Übersteuerung, fällt der
  // Resolver auf diese Basiswerte zurück. Gilt für ALLE Typen (Textil/Veredelung/Sonstiges).
  ekCents     Int       // Basis-Einkaufspreis (Standard-EK)
  vkCents     Int       // Basis-Verkaufspreis (Standard-VK)
  type        ArticleType @default(STOCK) // Artikeltyp-Diskriminator (STOCK/FINISHING/SERVICE/BOM) — einzige Quelle für „Veredelung"
  // Bestandsführung als Eigenschaft (Procure-to-Order): default KEIN Bestand (negative/
  // beliebige Mengen okay). Nur ausgewählte Artikel (Transferdrucke) sind bestandsgeführt
  // → volle Verfügbarkeits-/Reservierungs-/Meldebestand-/Shop-Puffer-Logik.
  bestandsgefuehrt Boolean @default(false)
  // Genau EIN (Textil-)Lieferant je Artikel — Quelle für EK und für die Aufschlagsmatrix
  // (VK = EK × Faktor(Lieferant, Kundengruppe)). Pflicht auf Service-/UI-Ebene (DB nullable
  // für migrationssicheren Backfill bestehender Artikel).
  supplierId  String?
  supplier    Supplier? @relation("ArticleSupplier", fields: [supplierId], references: [id])
  // Zugewiesener Veredler (Pflicht bei Veredelungs-/Logo-Artikeln, analog Textil-„Hersteller").
  veredlerId  String?
  veredler    Supplier? @relation("ArticleVeredler", fields: [veredlerId], references: [id])
  // Textil-PIM (B18). Faserzusammensetzung ist EU-Pflicht (VO 1007/2011).
  materialComposition String? // z. B. "100% Baumwolle"
  careInstructions    String?
  brand               String?
  hsCode              String? // Zolltarifnummer
  originCountry       String?
  // ERPNext-Item-Angleichung (Textil-Subset, Kap. 31): Artikelgruppe, Einheit, Verkauf/
  // Einkauf-Flags, Mindestbestellmenge, Max.-Rabatt, Lieferzeit + textilspezifisch.
  itemGroup      String? // Artikelgruppe (item_group)
  stockUom       String  @default("Stk") // Standardmaßeinheit (stock_uom)
  isSalesItem    Boolean @default(true) // Verkauf erlauben (is_sales_item)
  isPurchaseItem Boolean @default(true) // Einkauf zulassen (is_purchase_item)
  minOrderQty    Int? // Mindestbestellmenge (min_order_qty)
  maxDiscountPct Int? // Maximaler Rabatt % (max_discount)
  leadTimeDays   Int? // Lieferzeit in Tagen (lead_time_days)
  gender         String? // Herren/Damen/Kinder/Unisex (aus Lieferanten-Feeds)
  gm2            Int? // Flächengewicht g/m² (aus Lieferanten-Feeds)
  styleFit       String? // Passform (Slim/Regular/… aus Lieferanten-Feeds)
  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id])
  // Einrichtungskosten der Veredelung (Film/Sieb/Punch/Datei): FESTE Beträge — EK (unser Einkauf)
  // und VK (Kundenpreis), NICHT gerechnet. Fallen nur unter der Stückzahl-Schwelle an (< 10 Teile,
  // einmalig je Position). Nur bei Veredelungsartikeln gepflegt, sonst null.
  einrichtungEkCents Int?
  einrichtungVkCents Int?
  variants    Variant[]
  mediaAssets   MediaAsset[]
  finishingSpecs FinishingSpec[]
  // Mandant (ADR 0004, Slice 2) — Pflichtfeld mit Default: der Default "tenant_texma"
  // hält alle bestehenden create-Aufrufe grün (kein Call-Site-Refactor); er fällt in
  // Slice 4, wenn tenantId bei echter Multi-Tenant-Anlage überall explizit gesetzt wird.
  tenantId    String   @default("tenant_texma")
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([name])
  @@index([tenantId])
}

// Saison/Kollektion (B18, Kap. 3).
model Collection {
  id       String    @id @default(cuid())
  name     String
  season   String? // z. B. "FS26"
  articles Article[]
  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

// Digital Asset Management (B18) — Bilder, Druckvorlagen, Stickdateien.
enum MediaAssetKind {
  IMAGE
  PRINT_TEMPLATE
  EMBROIDERY_FILE
}

model MediaAsset {
  id        String         @id @default(cuid())
  articleId String?
  article   Article?       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  variantId String?
  variant   Variant?       @relation(fields: [variantId], references: [id], onDelete: Cascade)
  url       String
  kind      MediaAssetKind @default(IMAGE)
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([articleId])
  @@index([variantId])
  @@index([tenantId])
}

// Veredelungs-Metadaten je Artikel (B18) — Platzierung/Stichzahl/Farben.
enum FinishingMethod {
  STICK
  DRUCK // Siebdruck
  DRUCK_DIGITAL // Digitaldruck (DTG/DTF)
  TRANSFER
}

model FinishingSpec {
  id         String          @id @default(cuid())
  articleId  String
  article    Article         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  method     FinishingMethod
  placement  String // z. B. "Brust links", "Rücken"
  stitchCount Int?
  colorCount  Int?

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([articleId])
  @@index([tenantId])
}

model Variant {
  id         String  @id @default(cuid())
  articleId  String
  article    Article @relation(fields: [articleId], references: [id])
  sku        String  @unique
  // Übersteuert die Bestandsführung des Hauptartikels je Variante (null = erbt vom Artikel).
  bestandsgefuehrtOverride Boolean?
  // Echte Variantenstruktur: Attributnamen exakt "Farbe"/"Größe" (Kap. 3.2 / T-02)
  attributes VariantAttribute[]
  prices     PriceGroupPrice[]
  supplierItems SupplierItem[]
  bomItems   BomItem[]
  purchaseOrderLines PurchaseOrderLine[]
  goodsReceiptLines  GoodsReceiptLine[]
  incomingInvoiceLines IncomingInvoiceLine[] // EK-Abgleich Eingangsrechnung

  stockLevel StockLevel? // Lager/Bestand (T-12) — materialisierter Cache des Ledgers
  stockMoves StockMove[] // Bewegungs-Ledger (F4)
  stockReservations StockReservation[] // Vormerkungen gegen Aufträge
  stockThresholds   StockThreshold[]   // Meldebestände je Lager
  priceTiers PriceGroupPriceTier[] // Preisgruppen-Mengenstaffel (B4)
  customerPriceTiers CustomerPriceTier[] // kundenindividuelle Staffel (B4)
  // Set/Bundle-Stückliste (Kap. 5.1): isBundle-Variante löst sich in Komponenten auf.
  isBundle    Boolean @default(false)
  bundleComponents VariantComponent[] @relation("BundleParent") // Komponenten dieses Sets
  bundleUsages     VariantComponent[] @relation("BundleComponent") // Verwendung als Komponente
  gtin        String? // EAN/GTIN-13 (B18)
  weightGrams Int? // B18
  // Shop-Sicherheitspuffer (Pseudo-Bestand, Xentral-Vorbild): an den Shop gemeldeter Bestand =
  // max(0, verfügbar(HAUPT) − shopPuffer). Schützt vor Überverkauf / sichert eine Reserve.
  shopPuffer  Int     @default(0)
  mediaAssets MediaAsset[] // B18
  sampleLoans SampleLoan[] // Muster-Leihgut (B5)
  createdAt  DateTime @default(now())

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([articleId])
  @@index([tenantId])
}

// Stücklisten-Position einer Set-/Bundle-Variante (Kap. 5.1). qty = Menge je Set-Stück.
// componentVariant verlinkt optional auf eine reale Lagervariante (Bedarf/EK), sonst
// reine Freitext-Komponente (z. B. „Druck Brust links").
model VariantComponent {
  id                 String   @id @default(cuid())
  parentVariantId    String
  parent             Variant  @relation("BundleParent", fields: [parentVariantId], references: [id], onDelete: Cascade)
  componentVariantId String?
  component          Variant? @relation("BundleComponent", fields: [componentVariantId], references: [id])
  description        String
  qty                Int      @default(1)
  position           Int      @default(1)

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([parentVariantId])
  @@index([tenantId])
}

model VariantAttribute {
  id        String  @id @default(cuid())
  variantId String
  variant   Variant @relation(fields: [variantId], references: [id])
  name      String // "Farbe" | "Größe"
  value     String

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([variantId, name])
  @@index([name, value])
  @@index([tenantId])
}

// Matrixprodukt-Grundtabelle (Xentral-Vorbild, Kap. 2.1/3.2): wiederverwendbare
// Achse ("Gruppe": Farbe | Größe) mit gepflegten Werten ("Option": Navy, XL …).
// Global über alle Artikel nutzbar; je Option Sortierung, Aktiv-Flag und optionaler
// SKU-Anhang (sonst aus dem Wert abgeleitet). Lieferanten-Mapping folgt beim Import.
enum VariantAxis {
  FARBE
  GROESSE
}

model AxisValue {
  id        String      @id @default(cuid())
  axis      VariantAxis
  value     String // Option, kanonisch
  skuSuffix String? // „Anhang an Artikelnummer" (überschreibt die Ableitung)
  hex       String? // Farb-Hex für die UI (nur Farbe)
  sortOrder Int         @default(0)
  active    Boolean     @default(true)
  createdAt DateTime    @default(now())

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([axis, value])
  @@index([axis, sortOrder])
  @@index([tenantId])
}

// Größenlauf-Vorlage: füllt die Größen-Achse der Matrix per Klick (z. B. „Standard" = XS…XXL).
model SizeRun {
  id        String   @id @default(cuid())
  name      String   @unique
  values    String[]
  createdAt DateTime @default(now())
  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

// VK je Preisgruppe (Kap. 4.4/8.2). ERP = Preis-Master (Kap. 3.2 / T-08).
model PriceGroupPrice {
  id           String     @id @default(cuid())
  variantId    String
  variant      Variant    @relation(fields: [variantId], references: [id])
  priceGroupId String
  priceGroup   PriceGroup @relation(fields: [priceGroupId], references: [id])
  netCents     Int // Geldbeträge in Cent, niemals Float

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([variantId, priceGroupId])
  @@index([tenantId])
}

// Basispreis-Mengenstaffel je Preisgruppe (B4, Kap. 4.4). Gilt für alle Kunden der
// Gruppe. Stufenwahl: größte minMenge ≤ Bestellmenge.
model PriceGroupPriceTier {
  id           String     @id @default(cuid())
  variantId    String
  variant      Variant    @relation(fields: [variantId], references: [id])
  priceGroupId String
  priceGroup   PriceGroup @relation(fields: [priceGroupId], references: [id])
  minMenge     Int
  netCents     Int

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([variantId, priceGroupId, minMenge])
  @@index([tenantId])
}

// EK-Mengenstaffel je Variante (vor allem Veredelung/Stick): die Stickerei gibt uns ihren
// VK (= unseren EK) je Stück gestaffelt nach Bestellmenge. Anders als der flache
// SupplierItem.ekCents trägt diese Staffel je Stufe einen eigenen EK — Quelle für den
// Deckungsbeitrag je Stufe im Angebot (buildStaffelLadder). variantId als reine Spalte
// (wie OrderLine.variantId), kein Prisma-Relations-Zwang.
model VariantEkTier {
  id        String @id @default(cuid())
  variantId String
  minMenge  Int // untere Staffelgrenze in Stück (1, 10, 25, 50, 100, 250 …)
  ekCents   Int // EK je Stück in Cent (VK der Stickerei an uns) ab dieser Menge

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([variantId, minMenge])
  @@index([variantId])
  @@index([tenantId])
}

// Kundenindividuelle Basispreis-Staffel (B4). Höchste Präzedenz — sticht vor der
// Preisgruppen-Staffel und dem Einzelpreis.
model CustomerPriceTier {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  variantId String
  variant   Variant @relation(fields: [variantId], references: [id])
  minMenge  Int
  netCents  Int

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([companyId, variantId, minMenge])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Beschaffung / Lieferanten — Kap. 6, 13, 5.6 (Multi-Lieferant)
// ─────────────────────────────────────────────────────────────────────────────

// Lieferanten-Connector-Art (C3). Generischer Inbound-Connector je kind (Kap. 6/32).
enum SupplierKind {
  ID_IDENTITY
  STANLEY_STELLA
  HAKRO
  FHB_NEXMART
  MANUAL // kein Connector, manuelle Pflege
}

model Supplier {
  id              String   @id @default(cuid())
  name            String
  email           String? // zentrale E-Mail (Veredelungsauftrag-Versand an den Veredler, Kap. 5.3/5.4)
  vatId           String? // USt-IdNr. — Auflösung eingehender E-Rechnungen (Kap. 19/C4)
  iban            String? // Gläubiger-IBAN für SEPA-Überweisungen (PIS, Kap. 9)
  bic             String?
  // Stammdaten 360° (Paket 1): Adresse + Konditionen + Vermerk
  street          String?
  zip             String?
  city            String?
  country         String   @default("DE")
  zahlungszielTage Int     @default(14)
  skontoPercent   Int?
  skontoDays      Int?
  lieferzeitTage  Int? // typische Lieferzeit
  notiz           String?
  // DATEV-Kontierung (Kap. 9.2): kreditorische Seite. Fallback = Sammelkreditor bzw. Wareneingang.
  kreditorenkonto String? // Kreditorenkonto des Lieferanten
  aufwandskonto   String? // Aufwandskonto (Wareneingang/Fremdleistung)
  contacts        SupplierContact[]
  // Inbound-Connector (C3): Katalog/Lager/EK eingehend synchronisieren.
  kind            SupplierKind @default(MANUAL)
  baseUrl         String? // REST-Basis-URL des Lieferantensystems
  consumerKey     String? // Identifier (Klartext)
  consumerSecretEnc String? // Secret, AES-256-GCM verschlüsselt (DSGVO/Kap. 28)
  syncCursor      String? // Delta-Sync-Cursor (Kap. 13)
  active          Boolean  @default(true)
  supplierItems   SupplierItem[]
  textilArtikel   Article[] @relation("ArticleSupplier") // Artikel mit diesem (Textil-)Lieferanten
  customerGroups  CustomerSupplierPriceGroup[] // kundenindividuelle Gruppe je Kunde
  veredelungsArtikel Article[] @relation("ArticleVeredler") // als Veredler zugewiesene Logo-/Veredelungsartikel
  subProductions  SubProductionOrder[]
  stickereiKunden Company[] @relation("StickereiPartner")
  stickereiAngebote StickereiAngebot[] @relation("StickereiAngebote")
  purchaseOrders  PurchaseOrder[]
  incomingInvoices IncomingInvoice[]
  sampleLoanLines  SampleLoanLine[]
  // Mandant (ADR 0004, Slice 2) — Pflichtfeld mit Default: der Default "tenant_texma"
  // hält alle bestehenden create-Aufrufe grün (kein Call-Site-Refactor); er fällt in
  // Slice 4, wenn tenantId bei echter Multi-Tenant-Anlage überall explizit gesetzt wird.
  tenantId        String   @default("tenant_texma")
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  createdAt       DateTime @default(now())

  @@index([tenantId])
}

// Ansprechpartner je Lieferant (Paket 1) — analog Contact bei der Firma.
model SupplierContact {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  firstName  String
  lastName   String
  email      String?
  phone      String?
  role       String? // Funktion (z. B. Vertrieb, Disposition)
  createdAt  DateTime @default(now())

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([supplierId])
  @@index([tenantId])
}

model SupplierItem {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  variantId   String
  variant     Variant  @relation(fields: [variantId], references: [id])
  supplierSku String? // Lieferanten-Artikelnummer (Nachvollziehbarkeit, C3)
  ekCents     Int // Einkaufspreis in Cent
  availableQty Int? // Lieferanten-Verfügbarkeit (Lagerbestand, C3)
  priority    Int      @default(1) // 1 = Hauptlieferant, 2 = Alt-Lieferant (Kap. 6)
  minStock    Int? // Mindestbestand-Reorder (Kap. 6.3 / T-12)

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([supplierId, variantId])
  @@index([variantId, priority])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Integration — ShopConnector — Kap. 3, 18, 32. T-01 Firmenkunde-Mapping.
// ─────────────────────────────────────────────────────────────────────────────

enum ShopKind {
  WOOCOMMERCE
  SHOPIFY // generischer Shop-Adapter (Rückmeldung Status/Tracking, Kap. 4.2)
  ANFRAGESHOP // Kap. 18.1
  SAMMELBESTELLUNG // Kap. 18.2
}

// Versanddienstleister (Carrier) — bestimmt die Tracking-Link-Vorlage (DPD/DHL/GLS …).
enum Carrier {
  DPD
  DHL
  GLS
  UPS
  HERMES
  SONSTIGE
}

// Lieferadress-Regelung je Shop (K-08, Kap. 8.2)
enum DeliveryAddressPolicy {
  FEST // feste Firmen-Lieferadresse
  FREIE_EINGABE // Mitarbeiter gibt Adresse im Shop ein
  AUSWAHL // Büro wählt aus hinterlegten Firmen-Lieferadressen
}

// Ein Shop = eine Firma. companyId zeigt IMMER auf die Firma, nie auf Mitarbeiter (T-01).
model ShopConnector {
  id        String   @id @default(cuid())
  name      String
  kind      ShopKind @default(WOOCOMMERCE)
  baseUrl   String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  bomTemplateId String? // variable Stücklisten je Shop (Kap. 5.2/T-03, Extended Kap. 31)
  bomTemplate   BomTemplate? @relation(fields: [bomTemplateId], references: [id])
  active    Boolean  @default(true)
  deliveryAddressPolicy DeliveryAddressPolicy @default(FEST) // K-08
  syncCursor String? // Delta-Sync (Kap. 13)
  consumerKey      String? // WooCommerce REST consumer key (Identifier)
  consumerSecretEnc String? // consumer secret, AES-256-GCM verschlüsselt (DSGVO/Kap. 28)
  // Update-Strategie (Kap. 4.2): welche Statuswechsel an den Shop zurückgespielt werden;
  // notifyCustomer steuert, ob der Shop die Kunden-Mail auslösen soll (Mail an/aus).
  pushStatuses   OrderStatus[] @default([VERSENDET, STORNIERT])
  notifyCustomer Boolean       @default(true)
  // Bestellmodus je Shop (Kap. 18): SOFORT = Auftrag direkt; SAMMEL = Mitarbeiter-
  // bestellungen werden je Periode (sammelInterval) zu einer Sammelbestellung gebündelt.
  bestellmodus   String        @default("SOFORT") // SOFORT | SAMMEL
  sammelInterval String? // WOECHENTLICH | MONATLICH | QUARTALSWEISE | HALBJAEHRLICH (nur SAMMEL)
  orders    Order[]
  collectiveOrders CollectiveOrder[]
  createdAt DateTime @default(now())

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([companyId])
  @@index([tenantId])
}

/// Sammelbestellung (Kap. 18.2): bündelt Mitarbeiter-Shopbestellungen einer Periode zu
/// einem Vorgang. Die einzelnen Aufträge bleiben erhalten (collectiveOrderId), die
/// Detailansicht fasst Artikel und Veredelung über alle Mitglieder zusammen.
model CollectiveOrder {
  id              String        @id @default(cuid())
  number          String        @unique // SB-JAHR-NNNN
  shopConnectorId String
  shopConnector   ShopConnector @relation(fields: [shopConnectorId], references: [id])
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])
  interval        String // WOECHENTLICH | MONATLICH | QUARTALSWEISE | HALBJAEHRLICH
  periodStart     DateTime
  periodEnd       DateTime
  status          String        @default("OFFEN") // OFFEN | GEBUENDELT | UMGESETZT
  closedAt        DateTime?
  createdAt       DateTime      @default(now())
  orders          Order[]

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([shopConnectorId, periodStart])
  @@index([companyId])
  @@index([status])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Sales — Angebot → Auftrag — Kap. 4, 35.1/35.2
// ─────────────────────────────────────────────────────────────────────────────

enum QuoteStatus {
  ENTWURF
  VERSENDET
  NACHFASSEN // Wiedervorlage (Kap. 35.1)
  ANGENOMMEN
  ABGELEHNT
}

model Quote {
  id        String      @id @default(cuid())
  number    String      @unique
  companyId String
  company   Company     @relation(fields: [companyId], references: [id])
  status    QuoteStatus @default(ENTWURF)
  orderType String      @default("SALES") // Bestellart: SALES | MAINTENANCE | SHOPPING_CART
  quotationTo String    @default("CUSTOMER") // Angebot für: CUSTOMER | LEAD
  terms     String? // Geschäftsbedingungen (AGB-Text)
  workflowStage QuoteWorkflowStage @default(ANGEBOT_ANGELEGT) // Feinstatus (Workflow)
  wiedervorlageAm DateTime? // Nachfass-Termin (Kap. 35.1)
  gueltigBisAm DateTime? // Angebotsverfall (B8, Kap. 35.1)
  verlustgrund String? // Grund bei Ablehnung (B8, Kap. 35.1)
  zahlungszielTage Int? // Zahlungsziel in Tagen (Kopf; Default aus Kundenstamm)
  incoterm    String? // Lieferbedingung (Incoterm), z. B. EXW/DAP
  versandregel String? // Versandkosten-/Versandregel (frei/pauschal/nach Gewicht …)
  // Beleg-Kopffelder (Xentral-Parität): Projekt/Kostenstelle, interne Bezeichnung,
  // Kunden-Bestellnummer/Kommission, gewünschter Liefertermin.
  projekt            String?
  interneBezeichnung String?
  kommission         String?
  wunschLiefertermin DateTime?
  lines     QuoteLine[]
  order     Order?
  inquiry   Inquiry? // Ursprungs-Anfrage (B20)
  sampleLoans SampleLoan[] // aus dem Angebot gewandelte/zugeordnete Muster-Leihen (B5)
  // Mandant (ADR 0004, Slice 2) — Pflichtfeld mit Default: der Default "tenant_texma"
  // hält alle bestehenden create-Aufrufe grün (kein Call-Site-Refactor); er fällt in
  // Slice 4, wenn tenantId bei echter Multi-Tenant-Anlage überall explizit gesetzt wird.
  tenantId  String   @default("tenant_texma")
  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([tenantId])
}

// Anfrage-Funnel (B20, Kap. 18.1/35.1) — Vorbild Odoo crm.lead. NEU → IN_BEARBEITUNG
// → ANGEBOT (konvertiert zu Quote) oder VERWORFEN. ERP-Master des AF-Nummernkreises.
enum InquirySource {
  WEB
  EMAIL
  SHOP
  TELEFON
}

enum InquiryStatus {
  NEU
  IN_BEARBEITUNG
  ANGEBOT
  VERWORFEN
}

// Kundenportal-Identität (B13, Kap. 36) — VOLLSTÄNDIG getrennt von der Mitarbeiter-
// `User`-Tabelle (Sicherheits-Isolation). Jeder Portal-Login ist an GENAU eine Firma
// gebunden; die Mandanten-Isolation der Portal-API leitet sich aus `companyId` ab.
model PortalUser {
  id               String          @id @default(cuid())
  email            String          @unique
  passwordHash     String
  companyId        String
  company          Company         @relation(fields: [companyId], references: [id])
  active           Boolean         @default(true)
  failedLoginCount Int             @default(0)
  lockedUntil      DateTime? // Lockout nach zu vielen Fehlversuchen (Kap. 14)
  lastLoginAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  sessions         PortalSession[]

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([companyId])
  @@index([tenantId])
}

model PortalSession {
  id           String     @id @default(cuid())
  tokenHash    String     @unique // SHA-256 des Klartext-Tokens (nur im httpOnly-Cookie)
  portalUserId String
  portalUser   PortalUser @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  createdAt    DateTime   @default(now())

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([portalUserId])
  @@index([tenantId])
}

// Lead/Interessent (B15, Kap. 18.1) — leichter Prospect vor der Firma. Konvertierung
// erzeugt eine Company und verknüpft sie hier (convertedCompany).
enum LeadStatus {
  NEU
  KONTAKTIERT
  QUALIFIZIERT
  KONVERTIERT
  VERWORFEN
}

model Lead {
  id                 String        @id @default(cuid())
  name               String
  firma              String?
  webseite           String?
  verantwortlicher   String?       // Lead-Owner (Benutzer-E-Mail), für Zuweisung
  email              String?
  phone              String?
  quelle             InquirySource
  status             LeadStatus    @default(NEU)
  note               String?
  verworfenGrund     String?
  convertedCompanyId String?       @unique
  convertedCompany   Company?      @relation(fields: [convertedCompanyId], references: [id])
  createdAt          DateTime      @default(now())

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([status])
  @@index([tenantId])
}

model Inquiry {
  id             String        @id @default(cuid())
  number         String        @unique // AF-Nummernkreis (F1)
  companyId      String?
  company        Company?      @relation(fields: [companyId], references: [id])
  kontaktName    String?
  quelle         InquirySource
  status         InquiryStatus @default(NEU)
  verworfenGrund String?
  text           String
  quoteId        String?       @unique
