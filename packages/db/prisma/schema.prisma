  recipientCount Int                      @default(0)
  providerRef    String? // Brevo-Kampagnen-/Nachrichten-ID
  sentAt         DateTime?
  createdAt      DateTime                 @default(now())
  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
