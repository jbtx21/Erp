  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
}

// Aufgabe/Zuweisung (ERPNext „Assigned To/ToDo"): Beleg/Vorgang einer Person zuweisen,
// persönliche Arbeitsliste. Optional an einen Beleg gekoppelt (entity/entityId + navKey).
model Task {
  id            String    @id @default(cuid())
  title         String
  description   String?
  entity        String? // verknüpfter Beleg, z. B. "Order"
  entityId      String?
  navKey        String? // UI-Sprungziel
  assigneeEmail String
  createdBy     String?
  status        String    @default("OFFEN") // OFFEN | ERLEDIGT
  dueDate       DateTime?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([assigneeEmail, status])
  @@index([entity, entityId])
  @@index([tenantId])
}

// Persönliche UI-Einstellungen je Nutzer (Key-Value, Wert = JSON-String). Trägt z. B.
// das Home-Workspace-Layout, damit es geräteübergreifend gleich ist (statt localStorage).
model UserPreference {
  userId    String
  key       String // z. B. "home.shortcuts.v1"
  value     String // JSON-Wert (frei strukturiert)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@id([userId, key])
  @@index([tenantId])
}

// Automations-/Regel-Engine (Event → Bedingung → Aktion): im Admin-Portal konfigurierbar,
// läuft auf dem vorhandenen Event-Backbone. conditionsJson/actionsJson tragen die
// deklarative Regel (siehe @texma/shared automation.ts).
model AutomationRule {
  id            String   @id @default(cuid())
  name          String
  triggerEvent  String // z. B. "order.status.changed"
  conditionsJson String  @default("[]")
  actionsJson   String   @default("[]")
  active        Boolean  @default(true)
  lastFiredAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([triggerEvent, active])
  @@index([tenantId])
}

// Contact-Dynamic-Link (CRM-Muster ERPNext): entkoppelt Personen von genau EINER
// Firma. Eine Person kann zusätzlich mit beliebig vielen Parteien (Company, Lead,
// Supplier, …) verknüpft werden — polymorph über (entity, entityId).
model ContactLink {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  entity    String // "Company" | "Lead" | "Supplier" | …
  entityId  String
  role      String? // Funktion bei dieser Partei (z. B. "Einkauf", "Buchhaltung")
  createdAt DateTime @default(now())

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([contactId, entity, entityId])
  @@index([entity, entityId])
  @@index([tenantId])
}

// GoBD-Belegarchiv (Kap. 10): unveränderbares Register zum WORM-Objektspeicher. Die
// Bytes liegen inhaltsadressiert (storageKey = sha256) im Objektspeicher; hier nur
// Metadaten + Aufbewahrungsfrist + Legal Hold. Append-only (kein In-place-Update der Bytes).
model ArchivedDocument {
  id               String   @id @default(cuid())
  belegart         String
  sourceEntity     String
  sourceId         String
  fileName         String
  contentType      String
  sha256           String
  size             Int
  version          Int      @default(1)
  storageKey       String // = sha256 (inhaltsadressiert)
  retentionClass   String // BOOKING_10Y | BUSINESS_6Y
  earliestDeletion DateTime
  legalHold        Boolean  @default(false)
  archivedAt       DateTime @default(now())
  archivedBy       String?

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([sourceEntity, sourceId, sha256])
  @@index([belegart])
  @@index([archivedAt])
  @@index([tenantId])
}
