  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

enum NewsletterStatus {
  ENTWURF
  GESENDET
}

// Verkaufschance/Opportunity (komplexes CRM): gewichtete Pipeline. stage = Phase,
// Vereinheitlichter CRM-Funnel (IA-Objekt-Merge): EINE Entität + EINE Statusmaschine
// löst die drei früheren Backends Lead/Anfrage(Inquiry)/Chance(Opportunity) ab.
// Strangler: die alten Tabellen bleiben (grün), CrmLead ist die kanonische Entität.
enum CrmStage {
  NEU
  KONTAKTIERT
  QUALIFIZIERT
  ANGEBOT
  GEWONNEN
  VERLOREN
}

model CrmLead {
  id              String         @id @default(cuid())
  name            String
  companyId       String?
  company         Company?       @relation(fields: [companyId], references: [id])
  contactName     String?
  email           String?
  phone           String?
  source          InquirySource?
  stage           CrmStage       @default(NEU)
  valueCents      Int?
  probability     Int?
  expectedCloseAt DateTime?
  text            String?
  note            String?
  lostReason      String?
  quoteId         String? // gesetzt nach Angebotsüberführung
  // Konkrete Anfrage-Positionen (Mehr-Positionen-Erfassung wie im Angebot, inkl. Freitext auf
  // Artikel-/Veredelungsebene). JSON (Entwurfscharakter); beim Überführen → echte QuoteLines.
  lines           Json?
  legacyKind      String? // Backfill-Herkunft: LEAD | INQUIRY | OPPORTUNITY
  legacyId        String? // ID im alten Backend (Nachvollziehbarkeit)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([stage])
  @@index([companyId])
  @@index([tenantId])
}

// probability = Abschlusswahrscheinlichkeit (%), value = erwarteter Auftragswert.
// Gewichteter Forecast = Summe(value × probability) der offenen Chancen.
model Opportunity {
  id                String            @id @default(cuid())
  title             String
  companyId         String?
  company           Company?          @relation(fields: [companyId], references: [id])
  stage             OpportunityStage  @default(QUALIFIZIERUNG)
  valueCents        Int               @default(0)
  probability       Int               @default(10) // 0..100
  expectedCloseDate DateTime?
  status            OpportunityStatus @default(OFFEN)
  lostReason        String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([status])
  @@index([companyId])
  @@index([tenantId])
}

enum OpportunityStage {
  QUALIFIZIERUNG
  ANGEBOT
  VERHANDLUNG
  ABSCHLUSS
}

enum OpportunityStatus {
  OFFEN
  GEWONNEN
  VERLOREN
}

// Büro-Kalender (Terminmanagement): Termine, Urlaub, Abwesenheiten. ownerEmail =
// persönlich; null = für alle sichtbar. Externe Sync (CalDAV/Google) als Provider-Port.
model CalendarEvent {
  id         String            @id @default(cuid())
  title      String
  ownerEmail String? // null = geteilt/Büro-weit
  kind       CalendarEventKind @default(TERMIN)
  start      DateTime
  end        DateTime
  allDay     Boolean           @default(false)
  note       String?
  providerRef String? // externe Kalender-ID (Sync)
  // Verknüpfung zu einem Quell-Datensatz (z. B. Aufgabe): sourceEntity="task", sourceId=Task.id.
  // Aufgaben-Fälligkeiten erscheinen so im Kalender und bleiben zweiseitig synchron.
  sourceEntity String?
  sourceId     String?
  createdAt  DateTime          @default(now())

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([sourceEntity, sourceId])
  @@index([ownerEmail])
  @@index([start])
  @@index([tenantId])
}

enum CalendarEventKind {
  TERMIN
  URLAUB
  ABWESENHEIT
  SONSTIGES
  AUFGABE
}

// Mitarbeiter-Nachrichtenportal: interne Nachrichten zwischen Mitarbeitern.
model InternalMessage {
  id         String   @id @default(cuid())
  fromEmail  String
  toEmail    String
