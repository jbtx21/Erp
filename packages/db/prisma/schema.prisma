  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([orderId])
  @@index([companyId])
  @@index([tenantId])
}

// Gutschein/Wertgutschein (Xentral „Gutscheine"): Code mit Restguthaben + Gültigkeit.
