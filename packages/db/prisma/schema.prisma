  externalRef    String?       @unique // Mail-Message-ID (Idempotenz beim Maileingang)
  createdAt      DateTime      @default(now())

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([status])
  @@index([tenantId])
}

model QuoteLine {
  id          String  @id @default(cuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id])
  position    Int
  description String
  qty         Int
  unitNetCents Int // effektiver Netto-Einzelpreis NACH Positionsrabatt (Kap. 4.4)
  listNetCents Int? // VK-Listenpreis je Stück VOR Rabatt (Anzeige/Beleg); null = unitNetCents
  rabattPct   Int? // artikelbezogener Positionsrabatt in Prozent (0..100)
  taxRatePct  Int     @default(19) // USt-Satz je Position in Prozent (19 Regel, 7 ermäßigt)
  dbCents     Int? // Deckungsbeitrag bereits im Angebot sichtbar (Kap. 4.4)
  kind        PositionKind @default(TEXTIL) // Textil- vs. Veredelungsposition (Kap. 4.4/11)
  // Bezug: Hauptartikel (articleId, Variante offen) ODER konkrete Variante (variantId).
  // Bei der Auftragswandlung wird für reine Hauptartikel die Farbe×Größe abgefragt.
  articleId   String?
  variantId   String?
  // Veredelungsbezug (Kap. 5.4/11): Positionsnummern der Textilpositionen, auf die sich eine
  // Veredelung bezieht (z. B. Siebdruck → Positionen der T-Shirts). Mehrfach möglich; die
  // Veredelungsmenge korreliert mit der Summe der zugewiesenen Textilmengen. [] = ohne Bezug/frei.
  bezugPositionen Int[]
  // Alternativposition (Kunde wählt eine Variante) — wird bei der Auftragswandlung NICHT übernommen.
  isAlternative Boolean @default(false)
  // Positions-/Strukturzeile (Positionsmaske, Xentral-Vorbild): ARTIKEL | GRUPPE |
  // ZWISCHENSUMME | GRUPPENSUMME. Strukturzeilen tragen weder Menge/Preis noch zählen sie.
  lineType    String  @default("ARTIKEL")
  // Veredelungs-Platzierung am Textil (z. B. "Brust links", "Rücken") — speist das Werkstattblatt.
  placement   String?
  // Explizite Platzierungs-Skizze aus dem SVG-Positions-Picker (T-04): Kleidungstyp
  // (shirt|cap|hose), Ansicht (front|back|links|rechts|hinten) und Markerpunkt-Id (z. B. "bl").
  // Haben Vorrang vor der Heuristik in resolveGarmentPlacement; null = aus Text ableiten.
  positionType String?
  positionSide String?
  positionId   String?
  // Veredelungs-Detailfelder (Werkstattblatt-Karte): Motiv/Logo, Motivgröße, Farbton,
  // ausführliche Platzierungsbeschreibung, Sonstiges. Alle aus der Veredelungsposition erfasst.
  motiv             String?
  motivGroesse      String?
  farbton           String?
  platzierungsdetails String?
  sonstiges         String?
  // Alternativtext statt Euro-Betrag im Beleg-PDF (z. B. "nach Aufwand").
  altPreisText String?
  // Position im Beleg-PDF ausblenden (interne Position, Xentral "im PDF ausblenden").
  imPdfAusblenden Boolean @default(false)
  // Veredler je Veredelungs-Position (Fremdvergabe direkt aus dem Vertriebsweg, G1): hat
  // Vorrang vor dem Veredler des Katalogartikels. null = inhouse bzw. aus Artikel ableiten.
  veredlerId  String?
  // Verfügbar ab / zugesagter Liefertermin JE POSITION (Order-to-make, Kap. 35): TEXMA hat kein
  // Lager — nicht jede Variante ist sofort lieferbar. Treibt Teilproduktion/Teillieferung. null =
  // sofort/kein Termin gesetzt; der Kopf-Wunschtermin (Quote.wunschLiefertermin) bleibt davon unberührt.
  lieferdatum DateTime?
  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

enum OrderStatus {
  ANGELEGT
  IN_BEARBEITUNG // ab hier Änderung nur via Storno+Neuanlage (Kap. 4.4/12.1)
  IN_PRODUKTION
  VERSANDBEREIT
  VERSENDET
  FAKTURIERT // B9/K-26 (Kap. 35.2)
  ABGESCHLOSSEN // B9/K-26
  STORNIERT
}

// Teil-Erfüllungs-Status (ERP-Grundfunktion / G-4): delivery_status/billing_status-Muster.
enum FulfillmentStatus {
  NICHT
  TEILWEISE
  VOLL
}

model Order {
  id          String      @id @default(cuid())
  number      String      @unique
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id])
  deliveryAddressId String?
  deliveryAddress   DeliveryAddress? @relation(fields: [deliveryAddressId], references: [id])
  shopConnectorId String? // Herkunft Shop (null = manuell)
  shopConnector   ShopConnector? @relation(fields: [shopConnectorId], references: [id])
  // Zugehörige Sammelbestellung (Kap. 18.2); null = Einzel-/Sofortauftrag.
  collectiveOrderId String?
  collectiveOrder   CollectiveOrder? @relation(fields: [collectiveOrderId], references: [id])
  status      OrderStatus @default(ANGELEGT)
  lieferstatus FulfillmentStatus @default(NICHT) // Teil-Status (G-4) aus Lieferungen/Status
  fakturastatus FulfillmentStatus @default(NICHT) // Teil-Status (G-4) aus Rechnungsbetrag vs. Auftragssumme
  zugesagterLiefertermin DateTime? // Rückwärtsterminierung (B9, Kap. 35.2)
  route       OrderRoute? // Produktionsroute (Workflow/Statusverwaltung)
  routeStepIndex Int     @default(0) // aktueller Schritt in der Route
  quoteId     String?     @unique
  quote       Quote?      @relation(fields: [quoteId], references: [id])
  // Nachproduktion aus Reklamation (B11): Verweis auf den Ursprungsauftrag.
  nachproduktionVonId String?
  nachproduktionVon   Order?  @relation("Nachproduktion", fields: [nachproduktionVonId], references: [id])
  nachproduktionen    Order[] @relation("Nachproduktion")
  cashSales   CashSale[] // Barverkäufe (B6)
  fileLink    String? // Druckdaten-Verweis, Pflicht vor Produktion (Kap. 7.1)
  freigegeben Boolean     @default(false) // kein Produktionsstart ohne Freigabe (Kap. 5.2/7.2)
  fastLane    Boolean     @default(false) // Eilauftrag-Priorisierung (Xentral „Fast-Lane")
  // T-01: Mitarbeiter-Info des Shop-Kontos wird hier vermerkt, erzeugt KEINEN Kunden
  employeeNote String?
  externalNumber String? // Shop-Bestellnummer (Idempotenz beim Import, T-01)
  trackingNumber String? // DPD (Kap. 4.2/T-06)
  carrier        Carrier? // Versanddienstleister → Tracking-Link-Vorlage (Kap. 4.2)
  // Qualitätssicherung (QS-Gate vor Versand): Stückzahl + externe Veredelung kontrollieren,
  // Foto. Erst wenn BESTANDEN, ist der Auftrag versandbereit (listShippable).
  qsStatus       String   @default("OFFEN") // OFFEN | BESTANDEN
  qsStueckzahlOk Boolean  @default(false)
  qsVeredelungOk Boolean  @default(false)
  qsFotoOk       Boolean  @default(false)
  qsNotiz        String?
  qsGeprueftAm   DateTime?
  lines       OrderLine[]
  production  ProductionOrder?
  invoice     Invoice?
  abschlaege  Abschlagsrechnung[] // Abschlags-/Teilrechnungen (Xentral)
  deliveryNotes DeliveryNote[]
  complaints  Complaint[]
  // Bestellpositionen, die dieser Auftrag ausgelöst hat (MTO-Rückverweis, Kap. 6.1)
  purchaseOrderLineSources PurchaseOrderLineSource[]
  // Mandant (ADR 0004, Slice 2) — Pflichtfeld mit Default: der Default "tenant_texma"
  // hält alle bestehenden create-Aufrufe grün (kein Call-Site-Refactor); er fällt in
  // Slice 4, wenn tenantId bei echter Multi-Tenant-Anlage überall explizit gesetzt wird.
  tenantId    String   @default("tenant_texma")
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([shopConnectorId, externalNumber])
  @@index([companyId])
  @@index([status])
  @@index([tenantId])
}

model OrderLine {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id])
  position    Int
  description String
  qty         Int
  unitNetCents Int // effektiver Netto-Einzelpreis NACH Positionsrabatt
  listNetCents Int? // VK-Listenpreis je Stück VOR Rabatt (Anzeige/Beleg); null = unitNetCents
  rabattPct   Int? // artikelbezogener Positionsrabatt in Prozent (0..100)
  taxRatePct  Int  @default(19) // USt-Satz der Position zum Auftragszeitpunkt (eingefroren, GoBD); 0 = steuerbefreit
  dbCents     Int? // Deckungsbeitrag je Stück (VK − EK) zum Auftragszeitpunkt (Kap. 4.4)
  kind        PositionKind @default(TEXTIL) // Textil- vs. Veredelungsposition (Kap. 4.4/11)
  bezugPositionen Int[] // Veredelungsbezug: Positionsnummern der Textilpositionen (Kap. 5.4/11)
  variantId   String? // optionale Artikel-/Variantenverknüpfung (Bedarfsermittlung)
  rawPayload  Json? // Roh-Shopzeile für Replay/Traceability (Kap. 3)
  deliveryLines DeliveryNoteLine[] // gelieferte Teilmengen (Mehrfach-Teillieferung)
  // Alternativposition aus dem Angebot — am Auftrag eingefroren (GoBD), zählt nicht in die Summe.
  isAlternative Boolean @default(false)
  // Positions-/Strukturzeile (Positionsmaske): ARTIKEL | GRUPPE | ZWISCHENSUMME | GRUPPENSUMME.
  lineType    String  @default("ARTIKEL")
  placement   String? // Veredelungs-Platzierung (z. B. "Brust links") — speist das Werkstattblatt
  // Explizite Platzierungs-Skizze aus dem SVG-Positions-Picker (T-04): Vorrang vor der Heuristik.
  positionType String? // shirt | cap | hose
  positionSide String? // front | back | links | rechts | hinten
  positionId   String? // Markerpunkt-Id (z. B. "bl" = Brust links)
  // Veredelungs-Detailfelder (Werkstattblatt-Karte): Motiv/Logo, Größe, Farbton, Platzierungsdetails, Sonstiges.
  motiv             String?
  motivGroesse      String?
  farbton           String?
  platzierungsdetails String?
  sonstiges         String?
  altPreisText String? // Alternativtext statt Euro-Betrag im Beleg-PDF ("nach Aufwand")
  imPdfAusblenden Boolean @default(false) // Position im Beleg-PDF ausblenden
  // Veredler je Veredelungs-Position (Fremdvergabe direkt aus dem Vertriebsweg, G1): hat
  // Vorrang vor dem Veredler des Katalogartikels (loadOrderForProduction). null = inhouse/aus Artikel.
  veredlerId  String?
  // Verfügbar ab / zugesagter Liefertermin JE POSITION (Order-to-make, Kap. 35): aus dem Angebot
  // übernommen oder am Auftrag gepflegt. Treibt Teilproduktion/Teillieferung. null = sofort.
  lieferdatum DateTime?
  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
  // Aufrufe grün (kein Call-Site-Refactor); der Default fällt in Slice 4.
  tenantId String @default("tenant_texma")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

// Positionsart: Basistextil vs. Veredelung (Druck/Stick) vs. Sonstiges (Versand,
// Einrichtung). Trennt Umsatz/Produktion in Auftrag und Angebot (Veredelungskern).
enum PositionKind {
  TEXTIL
  VEREDELUNG
  SONSTIGE
}

// ─────────────────────────────────────────────────────────────────────────────
