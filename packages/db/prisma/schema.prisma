  isDefault  Boolean         @default(false) // persönliches Standard-Dashboard des Besitzers
  items      DashboardItem[]
  createdAt  DateTime        @default(now())

  // Mandant (ADR 0004, Slice 3) — Pflichtfeld mit Default: hält bestehende create-
